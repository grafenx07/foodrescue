# FoodRescue – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env to version control.

# PostgreSQL connection string
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/foodrescue"

# JWT signing secret — use a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# Server port
PORT=4000

# Set to "production" when deploying
NODE_ENV=development

# The exact origin your frontend is served from (no trailing slash)
# In production, replace with your domain, e.g. https://foodrescue.example.com
ALLOWED_ORIGIN=http://localhost:5173

# ─── SMTP (Gmail) ────────────────────────────────────────────────────────────
# Required for password-reset emails and platform notifications.
# Use a Gmail App Password (NOT your regular password).
# Steps:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Generate an App Password:   https://myaccount.google.com/apppasswords
#      (Select App: "Mail", Device: "Other" → copy the 16-char password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="FoodRescue <your@gmail.com>"

# Frontend URL — used inside emails as the base URL for reset links
# In production: https://your-domain.com
APP_URL=http://localhost:5173
