# FoodRescue – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env to version control.

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Pooled connection string (port 6543) — used at runtime by the server.
# From Supabase Dashboard → Settings → Database → Connection string → URI
# Switch the port from 5432 → 6543 and append ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection string (port 5432) — used by Prisma for db push / migrations.
# Same as above but on port 5432 and without the ?pgbouncer=true param.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret — use a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
# Set to "production" when deploying on Render
NODE_ENV=development

# The exact origin your frontend is served from (no trailing slash).
# In production: your Vercel deployment URL, e.g. https://foodrescue.vercel.app
ALLOWED_ORIGIN=http://localhost:5173

# ─── SMTP (Gmail) ────────────────────────────────────────────────────────────
# Required for password-reset emails and platform notifications.
# Use a Gmail App Password (NOT your regular password).
# Steps:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Generate an App Password:   https://myaccount.google.com/apppasswords
#      (Select App: "Mail", Device: "Other" → copy the 16-char password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="FoodRescue <your@gmail.com>"

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used inside emails as the base URL for reset links.
# In production: your Vercel URL, e.g. https://foodrescue.vercel.app
APP_URL=http://localhost:5173

# ─── Frontend (Vercel) ───────────────────────────────────────────────────────
# Set this in Vercel's dashboard as an Environment Variable (VITE_ prefix required).
# This tells the React client where to send API requests in production.
# Example: VITE_API_URL=https://foodrescue-api.onrender.com/api
# Leave blank for local dev (Vite proxy handles /api → localhost:4000).
VITE_API_URL=
