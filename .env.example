# FoodRescue – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env to version control.

# PostgreSQL connection string
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/foodrescue"

# JWT signing secret — use a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# Server port
PORT=4000

# Set to "production" when deploying
NODE_ENV=development

# The exact origin your frontend is served from (no trailing slash)
# In production, replace with your domain, e.g. https://foodrescue.example.com
ALLOWED_ORIGIN=http://localhost:5173
