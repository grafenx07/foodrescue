# FoodRescue – Frontend Environment Variables
# Copy this to client/.env for local overrides (it is gitignored).
# In production, set these in Vercel's "Environment Variables" dashboard.

# Full URL to the backend API (no trailing slash).
# Local dev: leave blank — Vite proxy forwards /api → http://localhost:4000
# Production: set to your Render backend URL
# Example: VITE_API_URL=https://foodrescue-api.onrender.com/api
VITE_API_URL=
